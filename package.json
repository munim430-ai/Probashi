{
  "name": "probashi",
  "version": "1.0.0",
  "description": "Probashi - A project management application",
  "private": true,
  "type": "module",
  "workspaces": [
    "deshantari-app"
  ],
  "scripts": {
    "dev": "npm --workspace=deshantari-app run dev",
    "build": "npm --workspace=deshantari-app run build",
    "lint": "npm --workspace=deshantari-app run lint",
    "preview": "npm --workspace=deshantari-app run preview",
    "install-all": "npm install && npm install --workspace=deshantari-app"
  },
  "keywords": [
    "probashi",
    "project",
    "management"
  ],
  "author": "munim430-ai",
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  }
}
